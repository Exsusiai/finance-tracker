# ============================================================
# Finance Tracker — 环境变量模板
# 复制为 .env 后修改 (.env 已在 .gitignore 中,不会被提交)
# ============================================================

# --- 鉴权 ---
# 必填: API token, 推荐 32 字节十六进制
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
FINANCE_TRACKER_API_TOKEN=replace-me-with-a-32-byte-random-hex-string

# --- 基础设置 ---
# 基础币种 (现金流汇总 / 总资产估值时折算到此币种)
# 记账域统一显示币种（cashflow / inbox / dashboard 现金流模块都用它）。
# 资产页面单独支持 CNY/USD/EUR/HKD/JPY/USDT/GBP 切换显示，不受这里限制。
BASE_CURRENCY=EUR

# 账户持有人姓名变体 (逗号分隔)。用于识别"自我转账"——
# 当银行账单两端都打印你自己的名字时，作为辅助配对线索。
# 示例: FINANCE_TRACKER_OWNER_NAMES=Jane Doe,Doe Jane,J. Doe
# 留空则跳过姓名匹配（IBAN / 账户名匹配仍生效）。
FINANCE_TRACKER_OWNER_NAMES=

# 后端监听 (默认 127.0.0.1 = 仅本机访问；如需 LAN 访问请改 0.0.0.0
# 同时确保 AUTH_DISABLED=false，否则启动会拒绝)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
LOG_LEVEL=INFO

# CORS 允许的前端 origin (逗号分隔)。生产部署时收窄到实际域名。
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3010,http://127.0.0.1:3000,http://127.0.0.1:3010

# --- 数据库 ---
# SQLite 文件路径 (相对项目根 / 容器内 /app)
DATABASE_URL=sqlite:///./data/finance.db

# --- 行情数据源 ---
# CoinGecko 免费版无需 key, Pro 版填此处
COINGECKO_API_KEY=
# yfinance 无需 key
# exchangerate.host 无需 key
# 黄金: goldapi.io 需要免费 key
GOLDAPI_KEY=

# 行情拉取间隔 (秒)
MARKET_REFRESH_CRYPTO_SEC=300
MARKET_REFRESH_STOCK_SEC=900
MARKET_REFRESH_FX_SEC=3600
MARKET_REFRESH_GOLD_SEC=3600

# --- 前端 ---
# Web UI 访问后端的根地址 (浏览器侧, 不含 /api/v1 后缀)。
# Next.js 在 build 时把 NEXT_PUBLIC_* 编进 bundle, 所以不要在这里写 secret。
# Token 不再走 NEXT_PUBLIC_* 注入 (那样会泄露到前端 bundle)，
# 用户在 Settings → API Token 输入框手动粘贴。
# 本地默认 AUTH_DISABLED=true + loopback 时不需要 token。
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- LLM 智能分类 (P1-1) ---
# 当 L1 关键词规则未命中或命中污染规则时, 后端会异步调用 LLM 进行兜底分类。
# 目前仅支持 Google Gemini (后续可扩展 OpenAI/Anthropic)。
# 取得 API Key: https://aistudio.google.com/apikey
#
# 推荐: 直接在前端 Settings → 「智能分类」section 输入 API key,
# 这里留空即可。Settings 页保存的 key 会优先于此处的 env 值。
# 仅当 Docker / 多设备共享配置场景才用 env 路径。
GEMINI_API_KEY=
# 注: provider/model/月度预算/置信度阈值/grounding 开关都存在 app_settings 表,
# 通过 Settings UI 修改即可, 不在此 env 配置。

# --- 链上加密钱包同步 (P1-4) ---
# Alchemy: 所有 EVM L1+L2 (Ethereum / Arbitrum / Optimism / Base / Polygon /
# zkSync / Linea / Scroll / Mantle / Blast) 的 ERC-20 余额发现都靠它。
# 免费 tier: 300M Compute Units / 月 (个人用十年都用不完)。
# 申请: https://www.alchemy.com → 创建 App → 复制 API Key
# 留空: EVM 链同步会被禁用，BTC / Solana / Tron 仍可正常工作。
ALCHEMY_API_KEY=
# Bitcoin (Blockstream Esplora) / Solana (公共 RPC) / Tron (TronGrid) 全部
# 使用公开免费端点，不需要 key。

# --- 凭据加密 (CEX API key + 银行同步 + LLM key) ---
# AES-256-GCM 对称加密所有外部服务凭据落库前的密钥。32 字节 = 64 hex。
# 生成: python -c "import os; print(os.urandom(32).hex())"
# 缺这个 key 时: 保存 Binance / Bitget API 凭据 / Gemini key 都会 4xx 失败。
# 注意: 一旦设置不要更换 - 换了之前加密的所有凭据都解不开。
FINANCE_BANK_ENCRYPTION_KEY=

# --- Notion 同步 (P2 阶段) ---
NOTION_TOKEN=
NOTION_TRANSACTIONS_DB_ID=
NOTION_CASHFLOW_DB_ID=
NOTION_ASSET_PAGE_ID=
NOTION_SYNC_ENABLED=false

# --- MCP Server ---
# MCP 直接连本地 SQLite,无需额外配置;
# 如需向 MCP 暴露受限子集,在此设置 (空 = 全开放)
MCP_ALLOWED_TOOLS=
