# ============================================================
# Finance Tracker — 环境变量模板
# 复制为 .env 后修改 (.env 已在 .gitignore 中,不会被提交)
# ============================================================

# --- 鉴权 ---
# 必填: API token, 推荐 32 字节十六进制
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
FINANCE_TRACKER_API_TOKEN=replace-me-with-a-32-byte-random-hex-string

# --- 基础设置 ---
# 基础币种 (现金流汇总 / 总资产估值时折算到此币种)
BASE_CURRENCY=CNY

# 后端监听
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# --- 数据库 ---
# SQLite 文件路径 (相对项目根 / 容器内 /app)
DATABASE_URL=sqlite:///./data/finance.db

# --- 行情数据源 ---
# CoinGecko 免费版无需 key, Pro 版填此处
COINGECKO_API_KEY=
# yfinance 无需 key
# exchangerate.host 无需 key
# 黄金: goldapi.io 需要免费 key
GOLDAPI_KEY=

# 行情拉取间隔 (秒)
MARKET_REFRESH_CRYPTO_SEC=300
MARKET_REFRESH_STOCK_SEC=900
MARKET_REFRESH_FX_SEC=3600
MARKET_REFRESH_GOLD_SEC=3600

# --- 前端 ---
# Web UI 访问后端的地址 (浏览器侧)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# --- Notion 同步 (P2 阶段) ---
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- MCP Server ---
# MCP 直接连本地 SQLite,无需额外配置;
# 如需向 MCP 暴露受限子集,在此设置 (空 = 全开放)
MCP_ALLOWED_TOOLS=
